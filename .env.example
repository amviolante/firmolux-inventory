# Copy this to .env and fill in your values
# On Railway, set these as Environment Variables in the dashboard

# PostgreSQL — Railway provides this automatically if you add a Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/railway

# ShipStation API credentials
# Found in: ShipStation → Account Settings → API Settings
SHIPSTATION_API_KEY=your_api_key_here
SHIPSTATION_API_SECRET=your_api_secret_here

# Optional: A shared secret to validate webhooks are really from ShipStation
# Set the same value in ShipStation webhook settings
SHIPSTATION_WEBHOOK_SECRET=

# Slack Incoming Webhook URL
# Created in: Slack → Apps → Incoming Webhooks → Add to Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# Dashboard password (change this!)
ADMIN_PASSWORD=firmolux2024

# Port (Railway sets this automatically)
PORT=3000
